<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:cardPreventCornerOverlap="true">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Foto de fundo com altura fixa para simetria no Grid -->
        <ImageView
            android:id="@+id/img_foto"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_photo_placeholder" />

        <!-- Gradiente escuro sutil sobre a imagem (na metade inferior) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_alignBottom="@id/img_foto"
            android:background="@drawable/gradient_dark" />

        <!-- Botão deletar (canto superior direito) - Estilo minimalista circular -->
        <ImageButton
            android:id="@+id/btn_deletar"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="8dp"
            android:padding="6dp"
            android:scaleType="fitCenter"
            android:src="@android:drawable/ic_menu_delete"
            android:background="@drawable/bg_delete_btn"
            android:visibility="gone"
            android:contentDescription="Remover foto" />

        <!-- Textos sobrepostos na parte inferior com alto contraste -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignBottom="@id/img_foto"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/tv_usuario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:maxLines="1"
                android:ellipsize="end"
                android:shadowColor="#80000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2" />

            <TextView
                android:id="@+id/tv_legenda"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="10sp"
                android:textColor="#E2E8F0"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginTop="2dp"
                android:visibility="gone"
                android:shadowColor="#80000000"
                android:shadowDx="1"
                android:shadowDy="1"
                android:shadowRadius="2" />
        </LinearLayout>

    </RelativeLayout>
</androidx.cardview.widget.CardView>
