<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- Foto -->
        <ImageView
            android:id="@+id/img_foto"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_photo_placeholder" />

        <!-- Botão deletar (canto superior direito) -->
        <ImageButton
            android:id="@+id/btn_deletar"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:layout_margin="4dp"
            android:src="@android:drawable/ic_menu_delete"
            android:background="@drawable/bg_delete_btn"
            android:visibility="gone"
            android:contentDescription="Remover foto" />

        <!-- Info na parte de baixo -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/img_foto"
            android:orientation="vertical"
            android:padding="6dp"
            android:background="@android:color/white">

            <TextView
                android:id="@+id/tv_usuario"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#212121"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/tv_legenda"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:textColor="#757575"
                android:maxLines="2"
                android:ellipsize="end"
                android:visibility="gone" />
        </LinearLayout>

    </RelativeLayout>
</androidx.cardview.widget.CardView>
