<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permissões de armazenamento para acessar fotos da galeria -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- permissões para utilização do MAPS -->

    <permission
        android:name="com.casaempresario.permission.MAPS_RECEIVE"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.casaempresario.permission.MAPS_RECEIVE" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="com.google.android.providers.gsf.permission.READ_GSERVICES" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <uses-feature
        android:glEsVersion="0x00020000"
        android:required="false" />


    <!-- INTERNET removida: o app é 100% local (Room/SQLite), sem chamadas de rede -->

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CasaEmpresario">

        <!-- metadados para utilização do MAPS -->
        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />

        <meta-data
            android:name="com.google.android.maps.v2.API_KEY"
            android:value="${mapsApiKey}"/>

        <!-- LOGIN — tela inicial do app -->
        <activity
            android:name=".activity.LoginActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- CADASTRO -->
        <activity
            android:name=".activity.RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".activity.LoginActivity" />

        <!-- MAIN — lista de eventos -->
        <activity
            android:name=".activity.MainActivity"
            android:exported="false" />

        <!-- DETALHE DO EVENTO (com galeria de fotos) -->
        <activity
            android:name=".activity.EventDetailActivity"
            android:exported="false"
            android:parentActivityName=".activity.MainActivity" />

        <!-- VISUALIZAR FOTO DO EVENTO COMO POST -->
        <activity
            android:name=".activity.PhotoPostActivity"
            android:exported="false"
            android:parentActivityName=".activity.EventDetailActivity" />

        <!-- CRIAR / EDITAR EVENTO (somente admin) -->
        <activity
            android:name=".activity.CreateEventActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".activity.MainActivity" />


        <!-- MAPA DE EVENTOS -->
        <activity
            android:name=".activity.MapActivity"
            android:exported="false"
            android:parentActivityName=".activity.MainActivity" />

        <!-- SELETOR DE LOCALIZAÇÃO (MAPA INTERATIVO) -->
        <activity
            android:name=".activity.LocationPickerActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".activity.CreateEventActivity" />

        <!-- CHAT E MENSAGENS -->
        <activity
            android:name=".activity.ChatActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".activity.MainActivity" />

    </application>
</manifest>
