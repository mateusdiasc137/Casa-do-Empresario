<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Permissões de armazenamento para acessar fotos da galeria -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- INTERNET removida: o app é 100% local (Room/SQLite), sem chamadas de rede -->

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CasaEmpresario">

        <!-- LOGIN — tela inicial do app -->
        <activity
            android:name=".activity.LoginActivity"
            android:exported="true"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- CADASTRO -->
        <activity
            android:name=".activity.RegisterActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".activity.LoginActivity" />

        <!-- MAIN — lista de eventos -->
        <activity
            android:name=".activity.MainActivity"
            android:exported="false" />

        <!-- DETALHE DO EVENTO (com galeria de fotos) -->
        <activity
            android:name=".activity.EventDetailActivity"
            android:exported="false"
            android:parentActivityName=".activity.MainActivity" />

        <!-- CRIAR / EDITAR EVENTO (somente admin) -->
        <activity
            android:name=".activity.CreateEventActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".activity.MainActivity" />

    </application>
</manifest>
